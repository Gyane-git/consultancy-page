// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// Admin User model
model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Category model
model Category {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?
  image       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  products    Product[]
}

// Product model
model Product {
  id                 Int       @id @default(autoincrement())
  productCode        String    @unique
  productName        String
  categoryId         Int?
  category           Category? @relation(fields: [categoryId], references: [id])
  brand              String?
  deliveryTargetDays Int?
  weeklyProduct      Boolean   @default(false)
  flashSaleProduct   Boolean   @default(false)
  todayDeals         Boolean   @default(false)
  specialProduct     Boolean   @default(false)
  actualPrice        Float?
  sellingPrice       Float?
  availableQuantity  Int?
  stockQuantity      Int?
  productDescription String?
  keySpecifications  String?
  packaging          String?
  warranty           String?
  productCatalog     String?
  productImages      String?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

// Banner model
model Banner {
  id        Int      @id @default(autoincrement())
  title     String
  subtitle  String?
  image     String
  link      String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Popup Ad model
model PopupAd {
  id        Int      @id @default(autoincrement())
  title     String
  content   String?
  image     String?
  link      String?
  isActive  Boolean  @default(true)
  showOnce  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
